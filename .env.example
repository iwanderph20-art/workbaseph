# ─────────────────────────────────────────────────────────────────────────────
# WorkBase PH — Environment Variables
# Copy this file to .env for local development.
# Set all variables in Railway dashboard for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://workbaseph.com                  # Production domain (used in payment redirect URLs)
NODE_ENV=production

# ── Security (CRITICAL — change both before going live) ──────────────────────
JWT_SECRET=replace-with-long-random-string      # Min 32 chars. Used to sign all auth tokens.
ADMIN_PASSWORD=replace-with-strong-password     # WorkBase admin panel password
ADMIN_EMAIL=admin@workbaseph.com                # Admin panel login email

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname   # Railway provides this automatically

# ── PayMongo (Payment Gateway) ────────────────────────────────────────────────
# Get these from: https://dashboard.paymongo.com → Developers → API Keys
PAYMONGO_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx     # Required — server-side only, never expose
PAYMONGO_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx     # Optional — not currently used client-side
PAYMONGO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx   # Required — from PayMongo webhook settings

# Webhook setup:
#   URL:    https://workbaseph.com/api/payments/webhook
#   Events: link.payment.paid
#   Copy the signing secret → PAYMONGO_WEBHOOK_SECRET

# ── PayMongo Amounts (PHP centavos — optional overrides) ─────────────────────
# Defaults are set in routes/payments.js. Override here if needed.
# PM_AMOUNT_PAY_PER_POST=84000      # ₱840  (~$15 Starter flat)
# PM_AMOUNT_ESSENTIAL=275000        # ₱2,750/mo (~$49 Essential)
# PM_AMOUNT_ESSENTIAL_ANNUAL=2750000 # ₱27,500/yr (~$490)
# PM_AMOUNT_PRO=445000              # ₱4,450/mo (~$79 Pro)
# PM_AMOUNT_PRO_ANNUAL=4450000      # ₱44,500/yr (~$790)
# PM_AMOUNT_AI_AUDIT=84000          # ₱840  (~$15 AI Audit add-on)
# PM_AMOUNT_FEATURED=84000          # ₱840  (~$15 Featured Listing)

# ── Email — Resend ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# Without this, emails log to console instead of sending (non-blocking).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── File Uploads ──────────────────────────────────────────────────────────────
# Set if using cloud storage for resumes/documents. Local disk used if not set.
# UPLOAD_PATH=/uploads

# ── AI Services (optional) ────────────────────────────────────────────────────
# Required only if AI Candidate Audit feature is active
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
